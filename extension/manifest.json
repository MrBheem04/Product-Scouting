{
  "manifest_version": 3,
  "name": "ScoutPrice Widget",
  "version": "1.0.0",
  "description": "Inject price histories, auto-coupon validations, and visual pricing checks directly into e-commerce pages.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.amazon.in/*",
    "https://*.flipkart.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.in/*",
        "https://*.flipkart.com/*"
      ],
      "js": ["content/content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ScoutPrice Quick Lookup"
  }
}
